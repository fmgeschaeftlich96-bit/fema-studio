{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/demo-marktfuehrer-pflege",
      "destination": "https://fontane-pflege.vercel.app",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*\\.jpg|.*\\.jpeg|.*\\.png|.*\\.svg|.*\\.ico|.*\\.webp|.*\\.avif)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*\\.css|.*\\.js|.*\\.woff2|.*\\.woff|.*\\.ttf)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*\\.html|/)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
